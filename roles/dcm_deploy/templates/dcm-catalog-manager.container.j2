[Unit]
Description=DCM Catalog Manager
After=dcm-postgres.service
Requires=dcm-postgres.service

[Container]
Image={{ dcm_image_registry }}/catalog-manager:{{ dcm_catalog_manager_version }}
ContainerName=catalog-manager
Network=dcm-network.network
Pull=always
EnvironmentFile={{ dcm_quadlet_dir }}/dcm.env
Environment=BIND_ADDRESS=:8080
Environment=DB_NAME=catalog-manager
Environment=PLACEMENT_MANAGER_URL=http://placement-manager:8080
HealthCmd=bash -c 'echo > /dev/tcp/localhost/8080'
HealthInterval=2s
HealthRetries=15
HealthTimeout=3s
HealthStartPeriod=10s

[Service]
Restart=always
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
